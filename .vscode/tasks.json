{
    "tasks": [
        {
            "label": "rckid-tools",
            "type": "shell",
            "command": "tools/rckid-tools-build.sh",
            "options": {
                "cwd": ""
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Generate assets",
            "type": "shell",
            "command": "tools/generate-assets.sh",
            "options": {
                "cwd": ""
            },
            "problemMatcher": []
        },
        {
            "label": "rckid/avr",
            "type": "shell",
            "command": "~/.platformio/penv/bin/pio",
            "args": [
                "run"
            ],
            "options": {
                "cwd": "${workspaceFolder}/rckid/avr",
                "shell": {
                    "executable": "/bin/zsh",
                    "args": [
                        "-c"
                    ]
                }
            },
            "problemMatcher": [
                "$platformio"
            ]
        },
        {
            "label": "rckid/avr [UPLOAD]",
            "command": "bash",
            "args": [
                "tools/pio-upload.sh",
                "rckid/avr"
            ],
            "options": {
                "cwd": ""
            },
            "problemMatcher": [
                "$platformio"
            ]
        },

        // ESP8266 base station that provides internet connection over NRF or LoRa radio. 
        {
            "label": "base-station",
            "type": "shell",
            "command": "~/.platformio/penv/bin/pio",
            "args": [
                "run"
            ],
            "options": {
                "cwd": "${workspaceFolder}/base-station",
                "shell": {
                    "executable": "/bin/zsh",
                    "args": [
                        "-c"
                    ]
                }
            },
            "problemMatcher": [
                "$platformio"
            ]
        },
        {
            "label" : "esp8266/base-station [UPLOAD]",
            "command" : "bash",
            "args": [
                "tools/pio-upload.sh",
                "base-station",
            ],
            "options": {
                "cwd": ""
            },
            "problemMatcher": [
                "$platformio"
            ]
        },
        
        {
            "label": "rckid - local [MOCK]",
            "command": "bash",
            "args": [
                "tools/build-mock.sh"
            ],
            "options": {
                "cwd": ""
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "rckid-games [MOCK]",
            "command": "bash",
            "args": [
                "tools/build-mock.sh",
                "games/games"
            ],
            "options": {
                "cwd": ""
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        // TODO is this still working??
        {
            "label": "gbc-tests [MOCK]",
            "command": "bash",
            "args": [
                "tools/build-mock.sh",
                "gbcemu/gbcemu-test"
            ],
            "options": {
                "cwd": ""
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ],
    "version": "2.0.0"
}
