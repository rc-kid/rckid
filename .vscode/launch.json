    "version": "0.2.0",
    "configurations": [
        {
            "name": "cartridge [fantasy]",
            "type": "cppdbg",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            //"program": "${workspaceFolder}/build/cartridges/tests/audiotest",
            "program": "${workspaceFolder}/build/cartridges2/test/ui-app",
            //"program": "${workspaceFolder}/build/cartridges/tests/bsodtest",
            "args": [],
            "stopAtEntry": false,
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description":  "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                },
            ]
        },
        {
            "name": "cartridge [mk3]",
            "type": "cppdbg",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/build-mk3/cartridges2/test/ui-app.elf",
            "args": [],
            "miDebuggerServerAddress": "10.0.0.38:3333",
            "stopAtEntry": false,
            "externalConsole": false,
            //"targetArchitecture": "arm-none-eabi-gdb",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description":  "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                },
            ]
        },
        {
            "name": "tests sdk & platform [fantasy]",
            "type": "cppdbg",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/build/sdk2/test/tests-sdk",
            "args": [],
            "stopAtEntry": false,
            "externalConsole": false,
            //"targetArchitecture": "arm64",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description":  "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                },
            ]
        },
    ]
}